+def _fix_misplaced_pod_config_spec(pod_config: Dict[str, Any]) -> None:
+    """Fix misplaced 'spec' nested under 'metadata' in pod_config.
+
+    A common YAML indentation mistake is placing 'spec' under 'metadata':
+
+        pod_config:
+          metadata:
+            labels: ...
+            spec:              # Wrong: nested under metadata
+              nodeSelector: ...
+
+    Instead of the correct structure:
+
+        pod_config:
+          metadata:
+            labels: ...
+          spec:                # Correct: sibling of metadata
+            nodeSelector: ...
+
+    This function detects the misplacement and moves spec-level keys
+    (like nodeSelector, tolerations, etc.) to the top level of pod_config.
+    """
+    metadata = pod_config.get('metadata')
+    if not isinstance(metadata, dict):
+        return
+
+    misplaced_spec = metadata.get('spec')
+    if not isinstance(misplaced_spec, dict):
+        return
+
+    # Known pod spec-level keys that should never appear under metadata
+    spec_keys = {
+        'nodeSelector', 'tolerations', 'affinity', 'schedulerName',
+        'runtimeClassName', 'priorityClassName', 'serviceAccountName',
+        'hostNetwork', 'dnsPolicy', 'terminationGracePeriodSeconds',
+    }
+    if not any(k in misplaced_spec for k in spec_keys):
+        return
+
+    logger.warning(
+        'Detected pod_config.metadata.spec in config - this is likely a YAML '
+        'indentation error. The "spec" key should be a sibling of "metadata", '
+        'not nested under it. Automatically relocating spec fields to the '
+        'correct level.'
+    )
+
+    # Move misplaced spec to the correct location
+    existing_spec = pod_config.get('spec', {})
+    if not isinstance(existing_spec, dict):
+        existing_spec = {}
+    config.merge_k8s_configs(existing_spec, misplaced_spec)
+    pod_config['spec'] = existing_spec
+
+    # Remove the misplaced spec from metadata
+    del metadata['spec']
+
+
